{
  "name": "@blacksmithers/obsidian-forge-mcp",
  "version": "0.4.0",
  "description": "Blazing-fast local MCP server for Obsidian vault operations via stdio",
  "type": "module",
  "bin": {
    "obsidian-forge": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blacksmithers/obsidian-forge-mcp.git"
  },
  "homepage": "https://github.com/blacksmithers/obsidian-forge-mcp",
  "keywords": [
    "obsidian",
    "mcp",
    "model-context-protocol",
    "typescript",
    "bm25",
    "search",
    "canvas",
    "vault",
    "ai-agents",
    "claude",
    "knowledge-management"
  ],
  "engines": {
    "node": ">=22"
  },
  "author": "Solutions Forge LTDA",
  "license": "MIT",
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@orama/orama": "^3.1.18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
